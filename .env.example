# Copy this file to .env for local development

# MongoDB connection string — get this from MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/medicine-companion

# Secret key for signing JWT tokens — make this long and random
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_chars

# Optional: Groq API key for the AI assistant
# Get one free at https://console.groq.com
# If you leave this blank, the app uses a built-in rule-based fallback
GROQ_API_KEY=

# Only needed on the backend Vercel project
# Set this to your frontend Vercel URL so CORS allows it
# e.g. https://medicare-app.vercel.app
CLIENT_URL=
